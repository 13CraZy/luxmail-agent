{
  "name": "luxmail-agent",
  "version": "1.0.0",
  "description": "Open-source local email monitor and WhatsApp AI notifier. Private-by-design.",
  "main": "dist/main/main/index.js",
  "scripts": {
    "dev:renderer": "vite",
    "dev:main": "tsc -w -p src/main",
    "dev": "concurrently \"npm run dev:renderer\" \"npm run dev:main\" \"electron .\"",
    "build:renderer": "vite build",
    "build:main": "tsc -p src/main",
    "build": "npm run build:renderer && npm run build:main",
    "start:service": "node dist/main/main/service.js",
    "lint": "eslint src --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,json}\"",
    "prepare": "husky"
  },
  "dependencies": {
    "@google/generative-ai": "^0.11.0",
    "dotenv": "^16.4.5",
    "electron-store": "^8.2.0",
    "express": "^4.19.2",
    "imapflow": "^1.0.155",
    "lucide-react": "^0.378.0",
    "openai": "^4.47.1",
    "qrcode-terminal": "^0.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "whatsapp-web.js": "^1.23.0",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@types/qrcode-terminal": "^0.12.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.3.0",
    "autoprefixer": "^10.4.19",
    "concurrently": "^8.2.2",
    "electron": "^30.0.6",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.0",
    "husky": "^9.0.11",
    "lint-staged": "^15.2.5",
    "postcss": "^8.4.38",
    "prettier": "^3.2.5",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "src/**/*.css": [
      "prettier --write"
    ]
  },
  "keywords": [
    "email",
    "imap",
    "gemini",
    "openai",
    "deepseek",
    "whatsapp",
    "ai",
    "agent",
    "private",
    "zero-trust"
  ],
  "author": "Felix Iniguez",
  "license": "MIT"
}
